# EditorConfig — https://editorconfig.org
root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false
indent_size = 2

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.{rs,c,cpp,cu,h,hpp}]
indent_size = 4

[*.py]
indent_size = 4

[*.{js,jsx,ts,tsx,html,css,scss}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{sv,v,vh,svh}]
indent_size = 2
