# =============================================================================
# .gitignore — RustySNES
# (negations `!` must follow the broad rule they re-include — order matters)
# =============================================================================

# --- Rust / Cargo ---
/target/
/target/doc/
/target/criterion/
**/*.rs.bk
*.bench
# This workspace ships a binary app — commit the lock (re-include it).
Cargo.lock
!/Cargo.lock

# --- Native build & FFI artifacts ---
*.so
*.dylib
*.dll
*.exe
*.a
*.lib
*.pdb

# --- WebAssembly / trunk / wasm-pack ---
/pkg/
/dist/
*.wasm
wasm-pack.log
# trunk build output (regenerated by `trunk build`; never committed).
/crates/rustysnes-frontend/web/dist/

# --- Node.js (web frontend) ---
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Python (helper scripts) ---
__pycache__/
*.pyc
.venv/
venv/

# --- Platform packages ---
*.AppImage
*.snap
*.flatpak
*.msi
*.appx
!**/snapshots/**/*.snap
!**/snapshots/*.snap
*.snap.new

# --- Fuzzing ---
fuzz/
!/fuzz/
/fuzz/target/
/fuzz/corpus/
/fuzz/artifacts/
/fuzz/coverage/
corpus/
artifacts/

# --- ROMs & media (copyright) ---
# The broad `*.sfc`/`*.smc` rules ignore ALL ROMs; re-include the committable
# permissive suites under tests/roms/, then HARD-exclude the commercial
# dumps + the large fetched clone (NEVER committed — Nintendo copyright).
*.sfc
*.smc
*.swc
*.fig
*.bs
*.ips
*.bps
*.ups
!/tests/roms/**/*.sfc
!/tests/roms/gilyon/**
!/tests/roms/undisbeliever/**
/tests/roms/external/
/game-roms/

# coverage tool's cached library-header scan
/scripts/coverage/.library-index.json
*.spc
*.rns
*.sav
*.srm
*.state
*.savestate
*.snapshot
*.quick*.state
*.rec
*.input
*.ram
*.dump
*.cht

# --- Game database files ---
*.db
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.dat
*.xml
!assets/**/*.xml

# --- Logs / debug / test output ---
*.log
*.test.log
*.golden
test-output/
/tests/captures/

# --- Coverage / profiling ---
*.gcno
*.gcda
coverage/
!/scripts/coverage/
!/scripts/coverage/**
tarpaulin-report.html
perf.data
perf.data.old
flamegraph.svg
/perf-logs/
*.profraw
*.profdata
/pgo-data/
/target/pgo/

# --- Documentation ---
/docs/_site/
/docs/audit/
/ref-proj/

# --- Temporary files ---
/tmp/
/temp/
*.tmp

# --- Merge / patch artifacts ---
*.orig
*.rej

# --- Environment ---
.env
.env.local

# --- Editors ---
.idea/
.vscode/
.zed/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
._*
Thumbs.db
Desktop.ini

# --- Android ---
android/**/build/
**/.gradle/
android/local.properties
android/keystore.properties
*.jks
*.keystore
android/app/src/main/jniLibs/

# --- iOS ---
ios/RustySNESFFI.xcframework/
ios/Generated/RustySNESCore.swift
ios/RustySNES.xcodeproj/
ios/build/
*.ipa
fastlane/report.xml
fastlane/README.md
fastlane/test_output/

# --- Pre-commit ---
.pre-commit-cache/

# --- AI assistant local files ---
GEMINI.md
CLAUDE.local.md
/.claude/
WARP.md
/.warp/

# Master-Claude backups
*.mc-bak

/salvaged/
