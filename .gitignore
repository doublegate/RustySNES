# =============================================================================
# .gitignore — RustySNES
# (negations `!` must follow the broad rule they re-include — order matters)
# =============================================================================

# --- Rust / Cargo ---
/target/
/target/doc/
/target/criterion/
**/*.rs.bk
*.bench
# This workspace ships a binary app — commit the lock (re-include it).
Cargo.lock
!/Cargo.lock

# --- Native build & FFI artifacts ---
*.so
*.dylib
*.dll
*.exe
*.a
*.lib
*.pdb

# Ad-hoc compiled debug helpers under scripts/ (e.g. `rustc scripts/foo.rs -o scripts/foo`)
# — the .rs source is committable, the extension-less binary it produces is not.
/scripts/parse_title

# --- WebAssembly / trunk / wasm-pack ---
/pkg/
/dist/
*.wasm
wasm-pack.log
# trunk build output (regenerated by `trunk build`; never committed).
/crates/rustysnes-frontend/web/dist/

# --- Node.js (web frontend) ---
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Python (helper scripts) ---
__pycache__/
*.pyc
.venv/
venv/

# --- Platform packages ---
*.AppImage
*.snap
*.flatpak
*.msi
*.appx
!**/snapshots/**/*.snap
!**/snapshots/*.snap
*.snap.new

# --- Fuzzing ---
fuzz/
!/fuzz/
/fuzz/target/
/fuzz/corpus/
/fuzz/artifacts/
/fuzz/coverage/
corpus/
artifacts/

# --- ROMs & media (copyright) ---
# The broad `*.sfc`/`*.smc` rules ignore ALL ROMs; re-include the committable
# permissive suites under tests/roms/, then HARD-exclude the commercial
# dumps + the large fetched clone (NEVER committed — Nintendo copyright).
*.sfc
*.smc
*.swc
*.fig
*.bs
*.ips
*.bps
*.ups
!/tests/roms/**/*.sfc
!/tests/roms/gilyon/**
!/tests/roms/undisbeliever/**
!/tests/roms/AccuracySNES/**
# ...but not the assembler's intermediates; only the source and the linked .sfc are committed.
/tests/roms/AccuracySNES/build/*.o
/tests/roms/AccuracySNES/build/*.map
/tests/roms/external/
/game-roms/

# coverage tool's cached library-header scan
/scripts/coverage/.library-index.json
*.spc
*.rns
*.sav
*.srm
*.state
*.savestate
*.snapshot
*.quick*.state
*.rec
*.input
*.ram
*.dump
*.cht

# --- Game database files ---
*.db
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.dat
*.xml
!assets/**/*.xml
!android/app/src/main/AndroidManifest.xml
!android/app/src/main/res/**/*.xml

# --- Logs / debug / test output ---
*.log
*.test.log
*.golden
test-output/
/tests/captures/

# --- Coverage / profiling ---
*.gcno
*.gcda
coverage/
!/scripts/coverage/
!/scripts/coverage/**
tarpaulin-report.html
perf.data
perf.data.old
flamegraph.svg
/perf-logs/
*.profraw
*.profdata
/pgo-data/
/target/pgo/

# --- Documentation ---
/docs/_site/
# Local SNESdev Wiki mirror (scripts/snesdev_wiki_mirror.py). Contributor-licensed upstream
# text — a local reference copy only, never vendored into the MIT/Apache tree. Mirrors the
# posture RustyNES takes with its own /nesdev_wiki/.
/snesdev_wiki/
/ref-proj
/ref-proj/

# Third-party reference material held locally for consultation and NEVER redistributed.
# Nintendo's SNES/Super Famicom developer documentation is Nintendo-copyrighted and was never
# publicly licensed; it is kept here the same way ref-proj/ holds GPL emulator clones and
# tests/roms/external/ holds commercial dumps — read, cite, re-express in our own words, never
# vendor. Both a file and a directory of each name are ignored, because an earlier `/ref-proj/`
# rule matched a directory but NOT a symlink and one got committed by accident.
/ref-docs/nintendo
/ref-docs/nintendo/
# Vendor datasheets (WDC / GTE / VLSI 65816). Manufacturer documents, freely distributed but
# all-rights-reserved — held for cross-vendor comparison, never vendored. Three renderings of the
# same instruction-operation table let a typo in any one be caught rather than inherited.
/ref-docs/datasheets
/ref-docs/datasheets/
/ref-docs/*.pdf
/ref-docs/*.PDF
/ref-docs/*.cbr
/ref-docs/*.zip

# --- Temporary files ---
/tmp/
/temp/
*.tmp

# --- Merge / patch artifacts ---
*.orig
*.rej

# --- Environment ---
.env
.env.local

# --- Editors ---
.idea/
.vscode/
.zed/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
._*
Thumbs.db
Desktop.ini

# --- Android ---
android/**/build/
**/.gradle/
android/local.properties
android/keystore.properties
*.jks
*.keystore
android/app/src/main/jniLibs/

# --- iOS ---
# `scripts/build-ios-xcframework.sh`'s real output paths (`v1.16.0 "Beacon"`) -- both are
# regenerated from Rust/UniFFI source on every build, matching `android/`'s identical
# never-commit-generated-bindings convention.
ios/Frameworks/
ios/RustySNES/Sources/Generated-RustysnesMobile.swift
ios/RustySNES/Sources/Generated-RustysnesMonetization.swift
ios/RustySNES.xcodeproj/
ios/build/
*.ipa
fastlane/report.xml
fastlane/README.md
fastlane/test_output/

# --- Pre-commit ---
.pre-commit-cache/

# --- AI assistant local files ---
GEMINI.md
CLAUDE.local.md
/.claude/
WARP.md
/.warp/

# Master-Claude backups
*.mc-bak

/salvaged/
